<Window x:Class="Hnxs.FontManager.DuplicateCandidatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="중복 후보 정리"
        Height="560"
        Width="860"
        MinHeight="460"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FB"
        FontFamily="Segoe UI">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="중복 후보 정리" FontSize="22" FontWeight="SemiBold" Foreground="#0D1B2A" />
            <TextBlock x:Name="SummaryText"
                       Text="같은 패밀리/스타일로 묶인 폰트 중 삭제 후보를 선택하세요."
                       Margin="0,6,0,16"
                       Foreground="#6B7A90" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="삭제 후보 자동 선택"
                    Height="34"
                    Padding="14,0"
                    Margin="0,0,8,0"
                    Click="AutoSelect_Click" />
            <Button Content="전체 해제"
                    Height="34"
                    Padding="14,0"
                    Click="ClearSelection_Click" />
        </StackPanel>

        <Border Grid.Row="2" Background="White" BorderBrush="#DDE5EF" BorderThickness="1">
            <DataGrid x:Name="CandidateGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="48"
                      IsReadOnly="False">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="삭제" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="56" />
                    <DataGridTextColumn Header="그룹" Binding="{Binding GroupName}" Width="180" IsReadOnly="True" />
                    <DataGridTextColumn Header="파일명" Binding="{Binding FileName}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="버전" Binding="{Binding Version}" Width="110" IsReadOnly="True" />
                    <DataGridTextColumn Header="상태" Binding="{Binding DuplicateState}" Width="110" IsReadOnly="True" />
                    <DataGridTextColumn Header="설치" Binding="{Binding InstalledState}" Width="130" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="취소"
                    Width="90"
                    Height="36"
                    Margin="0,0,8,0"
                    IsCancel="True" />
            <Button Content="선택 항목 삭제"
                    Width="126"
                    Height="36"
                    Background="#D83B01"
                    Foreground="White"
                    BorderBrush="#D83B01"
                    Click="DeleteSelected_Click" />
        </StackPanel>
    </Grid>
</Window>
