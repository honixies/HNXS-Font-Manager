<Window x:Class="Hnxs.FontManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HNXS Font Manager v0.1.0"
        Height="850"
        Width="1380"
        MinHeight="750"
        MinWidth="1220"
        Background="#F6F8FB"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="BorderBrush" Color="#DDE5EF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7A90" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0B66D8" />

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="16,3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="CenteredHeader" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CenteredCellText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="305" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F8FAFD" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="18,28,18,24">
                    <TextBlock Text="HNXS Font Manager"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#0D1B2A" />
                    <TextBlock Text="v0.1.0"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               Margin="1,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Content="⇪  폴더 가져오기"
                            Height="40"
                            Margin="16,0,16,8"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="White"
                            Click="ImportFolder_Click" />
                    <Button Content="▣  ZIP 가져오기"
                            Height="40"
                            Margin="16,0,16,8"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="White"
                            Click="ImportZip_Click" />
                    <CheckBox x:Name="IncludeSubfoldersCheckBox"
                              Content="하위 폴더 포함"
                              IsChecked="True"
                              Margin="20,8,16,24" />

                    <TextBlock Text="라이브러리" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="18,0,18,10" />
                    <Button Style="{StaticResource NavButton}" Background="#EAF3FF" Foreground="#0B66D8" Content="▣  모든 폰트" Click="AllFontsFilter_Click" />
                    <Button Style="{StaticResource NavButton}" Content="○  미설치" Click="UninstalledFilter_Click" />
                    <Button Style="{StaticResource NavButton}" Content="✓  설치됨" Click="InstalledFilter_Click" />
                    <Button x:Name="DuplicateNavButton" Style="{StaticResource NavButton}" Content="◇  중복 후보 (0)" Click="DuplicateCandidates_Click" />
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="18,0,18,22">
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16" />
                    <TextBlock Text="미리보기 설정" FontWeight="SemiBold" Foreground="#0D1B2A" />
                    <TextBlock Text="문구" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,12,0,6" />
                    <TextBox x:Name="PreviewTextBox"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="PreviewTextBox_TextChanged"
                             TextWrapping="Wrap"
                             MinHeight="170" />
                    <DockPanel Margin="0,12,0,4">
                        <TextBlock Text="크기" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <TextBlock Text="{Binding ElementName=PreviewSizeSlider, Path=Value, StringFormat={}{0:0} pt}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   HorizontalAlignment="Right" />
                    </DockPanel>
                    <Slider x:Name="PreviewSizeSlider" Minimum="18" Maximum="64" Value="20" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="270" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel Margin="18,8">
                    <TextBlock Text="검색"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0" />
                    <TextBox x:Name="SearchBox"
                             Width="430"
                             Height="36"
                             VerticalContentAlignment="Center"
                             Padding="14,0"
                             BorderThickness="0"
                             Background="#F3F6FA"
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="현재 폴더에서 폰트 검색" />
                    <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Content="중복 검사" Click="DuplicateCheck_Click" />
                    <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Content="취소" Click="Cancel_Click" />
                    <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Content="전체선택" Click="SelectAll_Click" />
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="18,18,18,10">
                <TextBlock Text="라이브러리  ›  프로젝트 에셋" Foreground="#8AA0BC" FontSize="12" />
                <TextBlock x:Name="CurrentSourceText" Text="소스를 선택하세요" FontSize="18" Foreground="#0D1B2A" Margin="0,8,0,2" />
                <TextBlock x:Name="SummaryText" Text="폴더 또는 ZIP 파일을 가져오면 폰트 목록이 표시됩니다." Foreground="{StaticResource MutedTextBrush}" />
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ManagedCountText" Text="0" FontWeight="SemiBold" Foreground="#0D1B2A" />
                    <TextBlock Grid.Column="1" Text=" files" Foreground="{StaticResource MutedTextBrush}" Margin="2,0,14,0" />
                    <TextBlock Grid.Column="2" x:Name="TotalSizeText" Text="0 MB" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Grid.Column="3" x:Name="TodayAddedText" Text="오늘 +0" Foreground="#00895A" HorizontalAlignment="Right" />
                </Grid>
                <ProgressBar x:Name="ScanProgress" Height="3" IsIndeterminate="False" Margin="0,8,0,0" />
            </StackPanel>

            <Border Grid.Row="2" Margin="18,0,18,14" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <DataGrid x:Name="FontGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          IsReadOnly="False"
                          RowHeight="44"
                          SelectionMode="Single"
                          SelectionChanged="FontGrid_SelectionChanged"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ColumnHeaderStyle="{StaticResource CenteredHeader}"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44" />
                        <DataGridTemplateColumn Header="폰트명 / 파일명" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="8,0">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#14213D" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding OriginalFileName}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="버전" Binding="{Binding Version}" Width="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredCellText}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="형식" Binding="{Binding Format}" Width="78" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredCellText}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="설치 상태" Binding="{Binding InstalledState}" Width="130" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredCellText}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="중복" Binding="{Binding DuplicateState}" Width="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CenteredCellText}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3" Margin="18,0,18,18" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="16,12,16,0">
                        <TextBlock Text="폰트 미리보기" FontWeight="SemiBold" Foreground="#0D1B2A" />
                        <TextBlock x:Name="PreviewFontNameText"
                                   Text="폰트를 선택하세요"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Right" />
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18,12,18,16">
                        <TextBlock x:Name="LargePreviewText"
                                   Text="미리보기"
                                   Language="ko-KR"
                                   FontSize="{Binding ElementName=PreviewSizeSlider, Path=Value}"
                                   Foreground="#14213D"
                                   TextWrapping="Wrap"
                                   TextAlignment="Left" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Button Style="{StaticResource PrimaryButton}" Content="선택 항목 설치" HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="InstallSelected_Click" />
                    <Button Style="{StaticResource IconButton}" Content="파일명 변경" HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="RenameSelected_Click" />
                    <TextBlock x:Name="SelectedCountText"
                               Text="선택 0개"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Margin="0,0,2,10" />
                    <ComboBox x:Name="InstallModeComboBox" Height="34" SelectedIndex="0" Margin="0,0,0,18">
                        <ComboBoxItem Content="현재 사용자 설치" />
                        <ComboBoxItem Content="시스템 전체 설치" />
                    </ComboBox>
                    <Button x:Name="RestartAsAdminButton"
                            Style="{StaticResource IconButton}"
                            Content="관리자 권한으로 다시 실행"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,18"
                            Click="RestartAsAdmin_Click" />

                    <TextBlock Text="폰트 정보" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="상세 정보를 보려면 폰트를 선택하세요." Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,14" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Text="버전" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VersionText" Text="-" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1" Text="제조사" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="FoundryText" Text="-" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="2" Text="디자이너" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DesignerText" Text="-" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="3" Text="언어 지원" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LanguageText" Text="-" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="4" Text="라이선스" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="LicenseText" Text="-" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </Grid>

                <StackPanel Grid.Row="2" Margin="0,18,0,0">
                    <TextBlock Text="작업 로그" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,8" />
                    <ListBox x:Name="LogList" Height="96" BorderBrush="{StaticResource BorderBrush}" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </StackPanel>

                <Button x:Name="SaveZipButton"
                        Grid.Row="3"
                        Content="ZIP 파일 변경사항 저장"
                        Height="42"
                        Background="#E7EDF6"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        Click="SaveZip_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
